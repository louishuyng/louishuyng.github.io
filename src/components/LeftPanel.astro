<!-- Left identity panel — Vercel dark -->
<aside id="left-panel" style="
  display:flex; flex-direction:column; justify-content:space-between;
  height:100%; padding:2.5rem 2.75rem;
  background:#000000;
  overflow-y:auto; position:relative;
  scrollbar-width:none;
">
<style>#left-panel::-webkit-scrollbar { display:none; }</style>

<!-- Scroll up arrow -->
<button id="lp-scroll-up" onclick="document.getElementById('left-panel').scrollBy({top:-160,behavior:'smooth'})" style="
  display:none; position:fixed; bottom:calc(50% + 24px); left:calc(19% - 22px);
  width:36px; height:36px; border-radius:50%;
  background:#1a1a1a; border:1px solid #5B6AD0;
  color:#5B6AD0; cursor:pointer; align-items:center; justify-content:center;
  transition:all 0.2s; z-index:10; font-size:16px; line-height:1;
  box-shadow:0 0 10px rgba(91,106,208,0.3);
">↑</button>

<!-- Scroll down arrow -->
<button id="lp-scroll-dn" onclick="document.getElementById('left-panel').scrollBy({top:160,behavior:'smooth'})" style="
  display:none; position:fixed; bottom:calc(50% - 64px); left:calc(19% - 22px);
  width:36px; height:36px; border-radius:50%;
  background:#1a1a1a; border:1px solid #5B6AD0;
  color:#5B6AD0; cursor:pointer; align-items:center; justify-content:center;
  transition:all 0.2s; z-index:10; font-size:16px; line-height:1;
  box-shadow:0 0 10px rgba(91,106,208,0.3);
">↓</button>

  <div style="position:relative;">

    <!-- Logo + hire me -->
    <div id="lp-logo" style="opacity:0; display:flex; align-items:center; justify-content:space-between; margin-bottom:3rem;">
      <span style="
        font-family:'JetBrains Mono'; font-size:11px;
        letter-spacing:0.18em; color:#555; text-transform:uppercase;
      ">louishuyng<span style="color:#5B6AD0; animation:blink 1s step-end infinite;">_</span></span>

      <a href="mailto:huynguyennbk@gmail.com" class="hire-btn" style="
        font-family:'DM Sans'; font-size:11px; font-weight:500;
        letter-spacing:0.06em; text-transform:uppercase;
        color:#A1A1AA; background:transparent;
        padding:6px 16px; text-decoration:none; border-radius:6px;
        border:1px solid #333; transition:all 0.2s;
      ">Hire me →</a>
    </div>

    <!-- Availability — flat, no box -->
    <div id="lp-avail" style="opacity:0; display:inline-flex; align-items:center; gap:8px; margin-bottom:2.5rem;">
      <span style="
        width:7px; height:7px; border-radius:50%; flex-shrink:0;
        background:#22c55e; box-shadow:0 0 6px rgba(34,197,94,0.8);
        animation:breathe-bright 2.4s ease infinite;
      "></span>
      <span style="font-family:'JetBrains Mono'; font-size:10px; letter-spacing:0.14em; text-transform:uppercase; color:#52525B;">
        Open to opportunities
      </span>
    </div>

    <!-- Name -->
    <h1 id="lp-name" style="opacity:1; line-height:0.9; margin-bottom:1.5rem;">
      <span id="name-line1" style="
        display:block; font-family:'JetBrains Mono',monospace; font-weight:700;
        font-size:clamp(3.2rem,5.6vw,5.5rem); color:#FFFFFF; letter-spacing:-0.03em;
      "></span>
      <span id="name-line2" style="
        display:block; font-family:'JetBrains Mono',monospace; font-weight:700;
        font-size:clamp(3.2rem,5.6vw,5.5rem); color:#5B6AD0; letter-spacing:-0.03em;
      "></span>
    </h1>

    <!-- Divider -->
    <div id="lp-rule" style="
      opacity:0; height:1px; max-width:140px; margin-bottom:1.25rem;
      background:linear-gradient(90deg, #333 0%, transparent 100%);
    "></div>

    <!-- Morphing role -->
    <div id="lp-role" style="opacity:0; position:relative; height:28px; overflow:hidden; margin-bottom:1.75rem;">
      <span id="morph-a" style="
        position:absolute; inset:0; display:flex; align-items:center;
        font-family:'JetBrains Mono'; font-size:12.5px; letter-spacing:0.06em; color:#52525B;
      ">Software Architect</span>
      <span id="morph-b" style="
        position:absolute; inset:0; display:flex; align-items:center;
        font-family:'JetBrains Mono'; font-size:12.5px; letter-spacing:0.06em; color:#52525B;
        transform:translateY(110%); opacity:0; filter:blur(4px);
      ">Cloud Engineer</span>
    </div>

    <!-- Bio -->
    <p id="lp-bio" style="
      opacity:0; font-family:'DM Sans'; font-size:17px; line-height:1.8; font-weight:400;
      color:#71717A; max-width:300px; margin-bottom:2.5rem;
    ">
      <span id="bio-text"></span><span id="bio-cursor" style="color:#5B6AD0; animation:blink 1s step-end infinite; display:none;">▌</span>
    </p>

    <!-- Stats — flat, no box -->
    <div id="lp-stats" style="opacity:0; display:flex; gap:2.5rem; margin-bottom:2.5rem;">
      {[
        { n:'8+', l:'Years' },
        { n:'∞',  l:'Scale' },
      ].map(s => (
        <div>
          <div style="font-family:'JetBrains Mono'; font-weight:700; font-size:2.2rem; color:#FFFFFF; line-height:1;">{s.n}</div>
          <div style="font-family:'JetBrains Mono'; font-size:9.5px; letter-spacing:0.22em; text-transform:uppercase; color:#3F3F46; margin-top:6px;">{s.l}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Links -->
  <div id="lp-links" style="opacity:0;">
    <div style="font-family:'JetBrains Mono'; font-size:8.5px; letter-spacing:0.26em; text-transform:uppercase; color:#3F3F46; margin-bottom:14px;">
      Find me at
    </div>
    <div style="display:flex; flex-direction:column; gap:9px;">
      {[
        { href:'https://github.com/louishuyng',           label:'GitHub'       },
        { href:'https://www.linkedin.com/in/louishuyng/', label:'LinkedIn'     },
        { href:'https://www.raycast.com/louishuyng',      label:'Raycast'      },
        { href:'https://www.credly.com/users/nguyen-louis/badges#credly', label:'Certificates' },
      ].map(l => (
        <a
          href={l.href}
          target={l.href.startsWith('http') ? '_blank' : undefined}
          rel="noopener"
          class="lp-link"
          style="
            font-family:'DM Sans'; font-size:15px; font-weight:400;
            color:#52525B; text-decoration:none;
            display:flex; align-items:center; gap:10px;
            width:fit-content; transition:color 0.18s;
          "
        >
          <span class="lp-tick" style="
            width:14px; height:1px; background:#333; flex-shrink:0;
            transition:width 0.25s cubic-bezier(0.16,1,0.3,1), background 0.18s;
          "></span>
          {l.label}
        </a>
      ))}
    </div>

    <div style="margin-top:2rem; font-family:'JetBrains Mono'; font-size:11px; color:#3F3F46; letter-spacing:0.03em;">
      Type <span style="color:#5B6AD0;">help</span> in the terminal →
    </div>
  </div>
</aside>

<style>
  .hire-btn:hover { background:#5B6AD0 !important; color:#fff !important; border-color:#5B6AD0 !important; }
  .lp-link:hover  { color:#E4E4E7 !important; }
  .lp-link:hover .lp-tick { width:28px !important; background:#5B6AD0 !important; }

  #lp-scroll-up, #lp-scroll-dn { pointer-events: auto; }
  @media (pointer: fine) {
    #lp-scroll-up:hover, #lp-scroll-dn:hover { background: rgba(255,255,255,0.12) !important; color: #aaa !important; }
  }

  /* ── Mobile: compact top bar ────────────────────────────── */
  @media (max-width: 767px) {
    #lp-scroll-up, #lp-scroll-dn { display: none !important; }
    #left-panel {
      height: auto !important;
      min-height: unset !important;
      padding: 0.9rem 1.25rem !important;
      flex-direction: column !important;
      justify-content: flex-start !important;
      overflow: hidden !important;
      border-bottom: 1px solid #1a1a1a;
    }

    /* First child becomes a single row: name left, hire-me right */
    #left-panel > div:first-child {
      display: flex !important;
      flex-direction: row !important;
      align-items: center !important;
      justify-content: space-between !important;
      width: 100% !important;
    }

    /* Hide everything except name and hire button */
    #lp-avail, #lp-rule, #lp-role, #lp-bio,
    #lp-stats, #lp-links { display: none !important; }

    /* Name on left, reorder before logo */
    #lp-name {
      order: 1 !important;
      margin-bottom: 0 !important;
      line-height: 1 !important;
    }
    #name-line1 { font-size: 1.3rem !important; display: inline !important; }
    #name-line2 { font-size: 1.3rem !important; display: inline !important; }
    #name-line2::before { content: '\00a0'; }

    /* Hire me button on right */
    #lp-logo {
      order: 2 !important;
      margin-bottom: 0 !important;
      flex-direction: row !important;
      align-items: center !important;
      justify-content: flex-end !important;
      flex-shrink: 0 !important;
    }

    /* Hide the louishuyng_ logo text, keep only the button */
    #lp-logo > span:first-child { display: none !important; }
  }
</style>

<script>
  import { animate } from 'motion';

  const ease = [0.16, 1, 0.3, 1] as [number,number,number,number];
  const sleep = (ms: number) => new Promise<void>(r => setTimeout(r, ms));

  // ── Scramble animation ────────────────────────────────────────
  const GLYPHS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789#@!$%';
  function scrambleTo(el: HTMLElement, target: string, duration = 1.1): Promise<void> {
    return new Promise(resolve => {
      const total = Math.ceil(duration * 60);
      let frame = 0;
      function tick() {
        const progress = frame / total;
        let result = '';
        for (let i = 0; i < target.length; i++) {
          if (target[i] === ' ') {
            result += ' ';
          } else if (progress >= (i + 1) / target.length) {
            result += target[i];
          } else {
            result += GLYPHS[Math.floor(Math.random() * GLYPHS.length)];
          }
        }
        el.textContent = result;
        frame++;
        if (frame <= total) requestAnimationFrame(tick);
        else { el.textContent = target; resolve(); }
      }
      el.textContent = GLYPHS[0];
      requestAnimationFrame(tick);
    });
  }

  // ── Typewriter animation ──────────────────────────────────────
  async function typewriter(textEl: HTMLElement, cursorEl: HTMLElement, segments: {text: string, style?: string}[], speed = 28) {
    cursorEl.style.display = 'inline';
    for (const seg of segments) {
      const span = document.createElement('span');
      if (seg.style) span.setAttribute('style', seg.style);
      textEl.appendChild(span);
      for (const ch of seg.text) {
        span.textContent += ch;
        await sleep(speed);
      }
    }
    await sleep(600);
    cursorEl.style.display = 'none';
  }

  // ── Fade-in sequence ─────────────────────────────────────────
  const fadeItems: [string, number][] = [
    ['#lp-logo',   0],
    ['#lp-avail',  120],
    ['#lp-rule',   1500],
    ['#lp-role',   1600],
    ['#lp-stats',  1800],
    ['#lp-links',  1950],
  ];

  fadeItems.forEach(([sel, delay]) => {
    const el = document.querySelector<HTMLElement>(sel);
    if (!el) return;
    animate(el, { opacity:[0,1], y:[18,0] }, { duration:0.65, delay:delay/1000, easing:ease });
  });

  // ── Name scramble ─────────────────────────────────────────────
  const line1 = document.getElementById('name-line1') as HTMLElement;
  const line2 = document.getElementById('name-line2') as HTMLElement;

  setTimeout(async () => {
    await Promise.all([
      scrambleTo(line1, 'LOUIS HUY', 2.2),
      scrambleTo(line2, 'NGUYEN', 1.9),
    ]);

    const bioEl   = document.getElementById('lp-bio') as HTMLElement;
    const bioText = document.getElementById('bio-text') as HTMLElement;
    const bioCur  = document.getElementById('bio-cursor') as HTMLElement;
    animate(bioEl, { opacity:[0,1] }, { duration:0.3, easing:ease });
    await typewriter(bioText, bioCur, [
      { text:'Senior engineer with ' },
      { text:'8+ years', style:'color:#E4E4E7;font-weight:600;' },
      { text:' designing scalable cloud architectures. Built systems handling ' },
      { text:'100K RPS', style:'color:#E4E4E7;font-weight:600;' },
      { text:'. Passionate about Kubernetes and open source.' },
    ], 22);
  }, 200);

  // ── Role morph ────────────────────────────────────────────────
  const roles = ['Software Architect','Cloud Engineer','System Designer','Open Source Dev','K8s Enthusiast'];
  let idx = 0;
  const a = document.getElementById('morph-a')!;
  const b = document.getElementById('morph-b')!;
  let active = a, incoming = b;

  async function morph() {
    idx = (idx + 1) % roles.length;
    incoming.textContent = roles[idx];

    await Promise.all([
      animate(active,   { y:[0,-110], opacity:[1,0], filter:['blur(0px)','blur(5px)'] },
        { duration:0.36, easing:[0.4,0,0.6,1] }).finished,
      animate(incoming, { y:[110,0],  opacity:[0,1], filter:['blur(5px)','blur(0px)'] },
        { duration:0.44, easing:ease }).finished,
    ]);
    [active, incoming] = [incoming, active];
    setTimeout(morph, 3200);
  }
  setTimeout(morph, 3400);

  // ── Scroll arrows ─────────────────────────────────────────────
  const panel  = document.getElementById('left-panel')!;
  const btnUp  = document.getElementById('lp-scroll-up') as HTMLButtonElement;
  const btnDn  = document.getElementById('lp-scroll-dn') as HTMLButtonElement;

  function updateArrows() {
    const canUp = panel.scrollTop > 10;
    const canDn = panel.scrollTop + panel.clientHeight < panel.scrollHeight - 10;
    btnUp.style.display = canUp ? 'flex' : 'none';
    btnDn.style.display = canDn ? 'flex' : 'none';
  }

  panel.addEventListener('scroll', updateArrows, { passive: true });
  // Check after animations complete
  setTimeout(updateArrows, 2500);

  [btnUp, btnDn].forEach(btn => {
    btn.addEventListener('mouseover', () => { btn.style.background='#5B6AD0'; btn.style.color='#fff'; btn.style.boxShadow='0 0 16px rgba(91,106,208,0.6)'; });
    btn.addEventListener('mouseout',  () => { btn.style.background='#1a1a1a'; btn.style.color='#5B6AD0'; btn.style.boxShadow='0 0 10px rgba(91,106,208,0.3)'; });
  });
</script>
