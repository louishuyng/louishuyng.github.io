---
const skills = [
  { name: "Golang",           icon: "🐹", level: 95 },
  { name: "Kubernetes",       icon: "⚙️",  level: 90 },
  { name: "Cloud (AWS/Azure/GCP)", icon: "☁️", level: 90 },
  { name: "Microservices",    icon: "🔗", level: 95 },
  { name: "API Design",       icon: "🔌", level: 90 },
  { name: "Data Pipelines",   icon: "📊", level: 85 },
  { name: "DevOps",           icon: "🚀", level: 85 },
  { name: "Ruby",             icon: "💎", level: 85 },
  { name: "Kafka",            icon: "📨", level: 82 },
  { name: "Terraform",        icon: "🏗️",  level: 80 },
  { name: "Node.js",          icon: "🟢", level: 78 },
  { name: "React Native",     icon: "📱", level: 75 },
];
---

<section id="skills" class="py-28 bg-white">
  <div class="max-w-6xl mx-auto px-6">

    <div class="text-center mb-16 reveal-skill" data-sd="0">
      <span class="inline-block font-mono text-xs tracking-[0.2em] uppercase text-purple-500 bg-purple-50 border border-purple-100 px-4 py-1.5 rounded-full mb-3">Expertise</span>
      <h2 class="text-4xl lg:text-5xl font-black text-slate-900">Skills & Technologies</h2>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
      {skills.map((s, i) => (
        <div
          class="skill-card bg-white border border-slate-100 rounded-2xl p-5 text-center hover:border-indigo-300 hover:shadow-xl hover:shadow-indigo-50 hover:-translate-y-1.5 transition-all duration-300"
          data-sd={i * 55}
          data-w={s.level}
          style="opacity:0; transform:translateY(30px);"
        >
          <div class="text-3xl mb-3 group-hover:scale-110">{s.icon}</div>
          <div class="text-sm font-semibold text-slate-800 mb-3 leading-tight">{s.name}</div>
          <div class="h-1.5 bg-slate-100 rounded-full overflow-hidden">
            <div class="skill-bar h-full bg-gradient-to-r from-indigo-500 to-purple-500 rounded-full w-0" style="transition:width 1s cubic-bezier(.4,0,.2,1) 0.3s;"></div>
          </div>
          <div class="text-xs font-mono text-slate-400 mt-1.5">{s.level}%</div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const cards = document.querySelectorAll<HTMLElement>('.skill-card');
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const card = e.target as HTMLElement;
      const delay = parseInt(card.dataset.sd ?? '0');
      const targetW = card.dataset.w + '%';
      setTimeout(() => {
        card.style.transition = 'opacity 0.55s ease, transform 0.55s ease';
        card.style.opacity = '1';
        card.style.transform = 'translateY(0)';
        const bar = card.querySelector<HTMLElement>('.skill-bar');
        if (bar) bar.style.width = targetW;
      }, delay);
      obs.unobserve(card);
    });
  }, { threshold: 0.12 });
  cards.forEach(c => obs.observe(c));
</script>
