---
const certs = [
  {
    title: "Claude Code In Action",
    issuer: "Skilljar / Anthropic",
    icon: "🤖",
    url: "https://verify.skilljar.com/c/jfnifed5mprf",
  },
  {
    title: "Cloud Badges & Certificates",
    issuer: "Credly — AWS, Azure & more",
    icon: "☁️",
    url: "https://www.credly.com/users/nguyen-louis/badges#credly",
  },
];
---

<section id="certifications" class="py-28 bg-slate-50">
  <div class="max-w-6xl mx-auto px-6">

    <div class="text-center mb-14 cert-reveal" data-sd="0">
      <span class="inline-block font-mono text-xs tracking-[0.2em] uppercase text-indigo-500 bg-indigo-50 border border-indigo-100 px-4 py-1.5 rounded-full mb-3">Achievements</span>
      <h2 class="text-4xl lg:text-5xl font-black text-slate-900">Certifications</h2>
    </div>

    <div class="grid sm:grid-cols-2 gap-6 max-w-3xl mx-auto">
      {certs.map((c, i) => (
        <a
          href={c.url}
          target="_blank"
          rel="noopener"
          class="cert-reveal group flex items-start gap-5 bg-white rounded-2xl p-6 border border-slate-100 hover:border-indigo-300 hover:shadow-xl hover:shadow-indigo-50/60 transition-all duration-300 hover:-translate-y-1"
          data-sd={i * 120}
          style="opacity:0; transform:translateY(30px);"
        >
          <div class="w-14 h-14 rounded-xl bg-indigo-50 border border-indigo-100 flex items-center justify-center text-2xl shrink-0 group-hover:scale-110 transition-transform duration-300">
            {c.icon}
          </div>
          <div class="min-w-0">
            <h3 class="font-bold text-slate-900 group-hover:text-indigo-600 transition-colors leading-snug">{c.title}</h3>
            <p class="text-sm text-slate-500 mt-1">{c.issuer}</p>
            <span class="inline-flex items-center gap-1 text-xs font-mono text-indigo-500 mt-2">
              View credential
              <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  const items = document.querySelectorAll<HTMLElement>('.cert-reveal');
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      const el = e.target as HTMLElement;
      const delay = parseInt(el.dataset.sd ?? '0');
      setTimeout(() => {
        el.style.transition = 'opacity 0.55s ease, transform 0.55s ease';
        el.style.opacity = '1';
        el.style.transform = 'none';
      }, delay);
      obs.unobserve(el);
    });
  }, { threshold: 0.1 });
  items.forEach(el => obs.observe(el));
</script>
